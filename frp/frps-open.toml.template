# frps-open.toml — frps v0.64 open gateway (no auth, no TLS) for legacy frpc clients
# Generated/managed by install-reflector.sh --install-frp
# Legacy frpc clients connect here with no token and no TLS requirement.

bindPort = 35735

[log]
to      = "/home/frp/frps-open.log"
level   = "info"
maxDays = 30

[webServer]
addr     = "0.0.0.0"
port     = 7500
user     = "admin"
password = "admin"
